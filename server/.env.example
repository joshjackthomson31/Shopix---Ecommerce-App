# =============================================
# Shopix Server — Environment Variables
# =============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ---- Server ----
PORT=5000
NODE_ENV=development        # development | production

# ---- Database ----
# Local MongoDB:  mongodb://localhost:27017/ecommerce
# MongoDB Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/ecommerce
MONGO_URI=mongodb://localhost:27017/ecommerce

# ---- Authentication ----
# Use a long, random string — e.g. openssl rand -hex 64
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRE=30d              # Token expiry e.g. 30d | 7d | 24h

# ---- CORS ----
# URL of the frontend (Vite dev default: 5173, CRA default: 3000)
CORS_ORIGIN=http://localhost:5173
